#!/bin/sh
echo "Content-Type: application/json"
echo ""

CMD=$(echo "$QUERY_STRING" | sed -n 's/.*cmd=\([^&]*\).*/\1/p')

case "$CMD" in
  on|off)
    /usr/bin/sonoff "$CMD" >/dev/null 2>&1
    echo "{\"status\":\"ok\",\"cmd\":\"$CMD\"}"
    ;;
  energy)
    DATA=$(/usr/bin/sonoff energy 2>&1)
    # Escape for JSON
    DATA=$(echo "$DATA" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\n' '\\' | sed 's/\\/\\n/g')
    echo "{\"status\":\"ok\",\"data\":\"$DATA\"}"
    ;;
  *)
    echo "{\"status\":\"error\",\"msg\":\"invalid command\"}"
    ;;
esac
